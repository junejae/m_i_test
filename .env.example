# MIG is created only on physical GPU 1.
# GPU 0 is currently occupied and excluded from this stack.
MIG_TARGET_GPU_INDEX=1

# Set these after running: nvidia-smi -L
MIG_UUID_1=MIG-REPLACE-WITH-UUID-1
MIG_UUID_2=MIG-REPLACE-WITH-UUID-2
MIG_UUID_3=MIG-REPLACE-WITH-UUID-3
MIG_UUID_4=MIG-REPLACE-WITH-UUID-4
MIG_UUID_5=MIG-REPLACE-WITH-UUID-5
MIG_UUID_6=MIG-REPLACE-WITH-UUID-6
MIG_UUID_7=MIG-REPLACE-WITH-UUID-7

# vLLM settings
MODEL_1=Qwen/Qwen3.5-4B
MODEL_2=Qwen/Qwen3-VL-8B-Instruct
MODEL_3=dragonkue/BGE-m3-ko
MODEL_4=Dongjin-kr/ko-reranker
ASR_MODEL_5=large-v3
MODEL_6=Qwen/Qwen3-TTS-12Hz-1.7B-Base
DIFFUSION_MODEL_7=runwayml/stable-diffusion-v1-5
SERVED_MODEL_NAME_1=qwen3.5-4b
SERVED_MODEL_NAME_2=qwen3-vl-8b-instruct
SERVED_MODEL_NAME_3=bge-m3-ko
SERVED_MODEL_NAME_4=ko-reranker
SERVED_MODEL_NAME_6=qwen3-tts-12hz-1.7b-base
VLLM_OPENAI_IMAGE_1=vllm/vllm-openai:v0.17.0
DTYPE_1=bfloat16
DTYPE_2=bfloat16
DTYPE_3=bfloat16
DTYPE_4=bfloat16
DTYPE_6=bfloat16
GPU_MEMORY_UTILIZATION_1=0.92
GPU_MEMORY_UTILIZATION_2=0.92
GPU_MEMORY_UTILIZATION_3=0.9
GPU_MEMORY_UTILIZATION_4=0.9
GPU_MEMORY_UTILIZATION_6=0.70
MAX_MODEL_LEN_1=4096
MAX_MODEL_LEN_2=2048
MAX_MODEL_LEN_3=512
MAX_MODEL_LEN_4=512
MAX_MODEL_LEN_6=256
MAX_NUM_SEQS_1=1
MAX_NUM_SEQS_2=1
MAX_NUM_SEQS_3=4
MAX_NUM_SEQS_4=4
MAX_NUM_SEQS_6=1
MAX_NUM_BATCHED_TOKENS_1=4096
MAX_NUM_BATCHED_TOKENS_2=1024
MAX_NUM_BATCHED_TOKENS_3=512
MAX_NUM_BATCHED_TOKENS_4=512
MAX_NUM_BATCHED_TOKENS_6=64
MM_IMAGE_LIMIT_2=1
MM_VIDEO_LIMIT_2=0
VLLM_EXTRA_ARGS_1=--swap-space 8 --enforce-eager --reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser qwen3_coder
VLLM_EXTRA_ARGS_2=--swap-space 24 --cpu-offload-gb 12 --enforce-eager
VLLM_EXTRA_ARGS_3=--swap-space 8
VLLM_EXTRA_ARGS_4=--swap-space 8
VLLM_EXTRA_ARGS_6=--swap-space 8 --enforce-eager

# ASR server settings (slot 5)
ASR_DEVICE_5=cuda
ASR_COMPUTE_TYPE_5=float16
ASR_BEAM_SIZE_5=1
ASR_LANGUAGE_5=ko
PORT_1=8101
PORT_2=8102
PORT_3=8103
PORT_4=8104
PORT_5=8105
PORT_6=8106
PORT_7=8107
GUARDRAILS_PORT=8111

# Diffusion server settings (slot 7)
DIFFUSION_DEVICE_7=cuda
DIFFUSION_DTYPE_7=float16
DIFFUSION_DEFAULT_HEIGHT_7=512
DIFFUSION_DEFAULT_WIDTH_7=512
DIFFUSION_DEFAULT_STEPS_7=20
DIFFUSION_DEFAULT_GUIDANCE_7=7.5
DIFFUSION_NEGATIVE_PROMPT_7=blurry,low-quality,distorted
DIFFUSION_ENABLE_CPU_OFFLOAD_7=0

# Bind per-model API ports to localhost by default.
API_BIND_HOST=127.0.0.1

# HTTPS proxy gateway (public entrypoint)
PROXY_BIND_HOST=0.0.0.0
PROXY_HTTPS_PORT=8443
PROXY_API_KEY=CHANGE-THIS-STRONG-KEY
# TLS server name/IP for proxy self-signed certificate CN/SAN.
PROXY_SERVER_NAME=127.0.0.1

# Guardrails proxy (slot1 only in the first rollout)
GUARDRAILS_UPSTREAM_BASE_URL=http://mig-vllm-1:8000
GUARDRAILS_EMBEDDINGS_BASE_URL=http://mig-vllm-3:8000
GUARDRAILS_SERVED_MODEL_NAME=${SERVED_MODEL_NAME_1}
GUARDRAILS_REQUEST_TIMEOUT_SECONDS=300
GUARDRAILS_ANALYZER_TIMEOUT_SECONDS=1.5
GUARDRAILS_PHASE1_ENABLED=1
GUARDRAILS_PHASE2_ENABLED=1
GUARDRAILS_PHASE3_ENABLED=1
GUARDRAILS_PHASE4_ENABLED=0
GUARDRAILS_PHASE2_MODE=observe
GUARDRAILS_PHASE3_MODE=observe
GUARDRAILS_FAIL_OPEN_ON_ANALYZER_TIMEOUT=1
GUARDRAILS_OUTPUT_SEMANTIC_NON_STREAM_ONLY=1
GUARDRAILS_RELEVANCE_ENABLED=0
GUARDRAILS_TOXICITY_ENABLED=1
GUARDRAILS_PII_ENABLED=1
GUARDRAILS_BLOCKLIST_PATH=/app/config/blocklist.txt
GUARDRAILS_CONFIG_PATH=/app/config/policy.json
GUARDRAILS_GOLDEN_SET_PATH=/app/config/golden_set.json
GUARDRAILS_MAX_INPUT_CHARS=12000
GUARDRAILS_MAX_STREAM_INPUT_CHARS=6000
GUARDRAILS_MAX_TOOL_COUNT=8
GUARDRAILS_MAX_MESSAGE_COUNT=64
GUARDRAILS_MAX_NON_STREAM_OUTPUT_CHARS=12000
GUARDRAILS_RATE_LIMIT_WINDOW_SECONDS=60
GUARDRAILS_RATE_LIMIT_MAX_REQUESTS=30
GUARDRAILS_OUTPUT_BLOCKLIST_ENFORCE=1
GUARDRAILS_TOXICITY_SAFE_THRESHOLD=0.3
GUARDRAILS_TOXICITY_DANGER_THRESHOLD=0.7
GUARDRAILS_RELEVANCE_SAFE_THRESHOLD=0.5
GUARDRAILS_METRICS_ENABLED=1

# Optional quick tunnel (Cloudflare) settings
TUNNEL_TARGET_URL=https://proxy-gateway:443
TUNNEL_LOGLEVEL=info

# Optional
HF_HOME=~/.cache/huggingface
HUGGING_FACE_HUB_TOKEN=
