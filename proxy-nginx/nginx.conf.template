server {
    listen 443 ssl;
    server_name _;

    ssl_certificate /etc/nginx/certs/server.crt;
    ssl_certificate_key /etc/nginx/certs/server.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 100m;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    location /slot1/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot1/(.*)$ /$1 break;
        proxy_pass http://mig-vllm-1:8000;
    }

    location /slot2/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot2/(.*)$ /$1 break;
        proxy_pass http://mig-vllm-2:8000;
    }

    location /slot3/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot3/(.*)$ /$1 break;
        proxy_pass http://mig-vllm-3:8000;
    }

    location /slot4/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot4/(.*)$ /$1 break;
        proxy_pass http://mig-vllm-4:8000;
    }

    location /slot5/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot5/(.*)$ /$1 break;
        proxy_pass http://mig-asr-5:8000;
    }

    location /slot6/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot6/(.*)$ /$1 break;
        proxy_pass http://mig-vllm-6:8000;
    }

    location /slot7/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        rewrite ^/slot7/(.*)$ /$1 break;
        proxy_pass http://mig-diffusion-7:8000;
    }

    location /slot7-ui/ {
        if ($http_x_api_key != "${PROXY_API_KEY}") { return 401; }
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_pass http://mig-diffusion-ui-7:7860/;
    }

    location / {
        return 404;
    }
}
